{
  "name": "@adonisjs/static",
  "version": "2.0.0",
  "description": "Static file server for AdonisJS",
  "main": "build/index.js",
  "type": "module",
  "files": [
    "build",
    "!build/bin",
    "!build/tests"
  ],
  "engines": {
    "node": ">=24.0.0"
  },
  "exports": {
    ".": "./build/index.js",
    "./types": "./build/src/types.js",
    "./static_middleware": "./build/src/static_middleware.js",
    "./static_provider": "./build/providers/static_provider.js"
  },
  "scripts": {
    "pretest": "npm run lint",
    "test": "cross-env NODE_DEBUG=adonisjs:static npm run quick:test",
    "lint": "eslint",
    "format": "prettier --write .",
    "typecheck": "tsc --noEmit",
    "copy:templates": "copyfiles --up 1 \"stubs/**/*.stub\" build",
    "precompile": "npm run lint && npm run clean",
    "clean": "del-cli build",
    "compile": "tsup-node && tsc --emitDeclarationOnly --declaration",
    "postcompile": "npm run copy:templates",
    "build": "npm run compile",
    "docs": "typedoc",
    "version": "npm run build",
    "prepublishOnly": "npm run build",
    "release": "release-it",
    "quick:test": "node --import=@poppinss/ts-exec --enable-source-maps bin/test.ts"
  },
  "devDependencies": {
    "@adonisjs/assembler": "^8.0.0",
    "@adonisjs/core": "^7.0.0",
    "@adonisjs/eslint-config": "^3.0.0",
    "@adonisjs/prettier-config": "^1.4.5",
    "@adonisjs/tsconfig": "^2.0.0",
    "@japa/assert": "^4.2.0",
    "@japa/file-system": "^3.0.0",
    "@japa/runner": "^5.3.0",
    "@poppinss/ts-exec": "^1.4.4",
    "@release-it/conventional-changelog": "^10.0.5",
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^25.3.0",
    "@types/serve-static": "^2.2.0",
    "@types/supertest": "^6.0.3",
    "c8": "^11.0.0",
    "copyfiles": "^2.4.1",
    "cross-env": "^10.1.0",
    "del-cli": "^7.0.0",
    "eslint": "^10.0.2",
    "fs-extra": "^11.3.3",
    "prettier": "^3.8.1",
    "release-it": "^19.2.4",
    "supertest": "^7.2.2",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "serve-static": "^2.2.1"
  },
  "peerDependencies": {
    "@adonisjs/assembler": "^8.0.0-next.7 || ^8.0.0",
    "@adonisjs/core": "^7.0.0-next.0 || ^7.0.0"
  },
  "peerDependenciesMeta": {
    "@adonisjs/assembler": {
      "optional": true
    }
  },
  "homepage": "https://github.com/adonisjs/static#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/adonisjs/static.git"
  },
  "bugs": {
    "url": "https://github.com/adonisjs/static/issues"
  },
  "keywords": [
    "static",
    "adonisjs",
    "static-middleware",
    "static-file-server"
  ],
  "author": "Harminder Virk <virk@adonisjs.com>",
  "license": "MIT",
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "tsup": {
    "entry": [
      "./index.ts",
      "./src/types.ts",
      "./src/static_middleware.ts",
      "./providers/static_provider.ts"
    ],
    "outDir": "./build",
    "clean": true,
    "format": "esm",
    "dts": false,
    "sourcemap": false,
    "target": "esnext"
  },
  "release-it": {
    "git": {
      "requireCleanWorkingDir": true,
      "requireUpstream": true,
      "commitMessage": "chore(release): ${version}",
      "tagAnnotation": "v${version}",
      "push": true,
      "tagName": "v${version}"
    },
    "github": {
      "release": true
    },
    "npm": {
      "publish": true,
      "skipChecks": true
    },
    "plugins": {
      "@release-it/conventional-changelog": {
        "preset": {
          "name": "angular"
        }
      }
    }
  },
  "c8": {
    "reporter": [
      "text",
      "html"
    ],
    "exclude": [
      "**/build/lodash/**",
      "tests/**",
      "test_helpers/**"
    ]
  },
  "prettier": "@adonisjs/prettier-config"
}
