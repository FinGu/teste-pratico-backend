{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "declaration": false,
    "sourceMap": true,
    "rewriteRelativeImportExtensions": true,
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "types": ["@types/node"]
  },
  "include": [
    "${configDir}/**/*",
    "${configDir}./.adonisjs/server/**/*"
  ],
  "exclude": [
    "${configDir}/inertia/**",
    "${configDir}/node_modules/**",
    "${configDir}/build/**",
    "${configDir}/bower_components/**",
    "${configDir}/jspm_packages/**"
  ]
}