{
  "name": "@japa/plugin-adonisjs",
  "version": "5.1.0",
  "description": "A bridge between AdonisJS and Japa",
  "main": "build/index.js",
  "files": [
    "build",
    "!build/bin",
    "!build/tests",
    "!build/tests_helpers"
  ],
  "exports": {
    ".": "./build/index.js"
  },
  "engines": {
    "node": ">=18.16.0"
  },
  "type": "module",
  "scripts": {
    "pretest": "npm run lint",
    "test": "cross-env NODE_DEBUG=adonisjs:http npm run quick:test",
    "typecheck": "tsc --noEmit",
    "clean": "del-cli build",
    "precompile": "npm run lint && npm run clean",
    "compile": "tsdown && tsc --emitDeclarationOnly --declaration",
    "build": "npm run compile",
    "prebenchmark": "npm run build",
    "benchmark": "node benchmarks/index.js",
    "release": "release-it",
    "version": "npm run build",
    "format": "prettier --write .",
    "prepublishOnly": "npm run build",
    "lint": "eslint",
    "quick:test": "node --import=@poppinss/ts-exec --enable-source-maps bin/test.ts",
    "docs": "typedoc"
  },
  "devDependencies": {
    "@adonisjs/core": "^7.0.0",
    "@adonisjs/eslint-config": "^3.0.0",
    "@adonisjs/prettier-config": "^1.4.5",
    "@adonisjs/tsconfig": "^2.0.0",
    "@japa/api-client": "^3.2.1",
    "@japa/assert": "^4.2.0",
    "@japa/browser-client": "^2.3.0",
    "@japa/runner": "^5.3.0",
    "@poppinss/ts-exec": "^1.4.4",
    "@release-it/conventional-changelog": "^10.0.5",
    "@types/node": "^25.3.0",
    "c8": "^11.0.0",
    "cross-env": "^10.1.0",
    "del-cli": "^7.0.0",
    "eslint": "^10.0.2",
    "get-port": "^7.1.0",
    "playwright": "^1.58.2",
    "prettier": "^3.8.1",
    "release-it": "^19.2.4",
    "tsdown": "^0.20.3",
    "typescript": "^5.9.3"
  },
  "peerDependencies": {
    "@adonisjs/core": "^7.0.0-next.21 || ^7.0.0",
    "@japa/api-client": "^3.1.0",
    "@japa/browser-client": "^2.2.0",
    "@japa/runner": "^4.0.0 || ^5.0.0",
    "playwright": "^1.57.0"
  },
  "peerDependenciesMeta": {
    "@japa/api-client": {
      "optional": true
    },
    "@japa/browser-client": {
      "optional": true
    },
    "playwright": {
      "optional": true
    }
  },
  "keywords": [
    "plugin-adonisjs",
    "japa-plugin"
  ],
  "license": "MIT",
  "author": "Harminder Virk <virk@adonisjs.com>",
  "homepage": "https://github.com/japa/plugin-adonisjs#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/japa/plugin-adonisjs.git"
  },
  "bugs": {
    "url": "https://github.com/japa/plugin-adonisjs/issues"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "tsdown": {
    "entry": [
      "./index.ts"
    ],
    "outDir": "./build",
    "clean": true,
    "format": "esm",
    "minify": "dce-only",
    "fixedExtension": false,
    "dts": false,
    "treeshake": false,
    "sourcemaps": false,
    "target": "esnext"
  },
  "release-it": {
    "git": {
      "requireCleanWorkingDir": true,
      "requireUpstream": true,
      "commitMessage": "chore(release): ${version}",
      "tagAnnotation": "v${version}",
      "push": true,
      "tagName": "v${version}"
    },
    "github": {
      "release": true
    },
    "npm": {
      "publish": true,
      "skipChecks": true
    },
    "plugins": {
      "@release-it/conventional-changelog": {
        "preset": {
          "name": "angular"
        }
      }
    }
  },
  "c8": {
    "reporter": [
      "text",
      "html"
    ],
    "exclude": [
      "tests/**"
    ]
  },
  "prettier": "@adonisjs/prettier-config"
}
